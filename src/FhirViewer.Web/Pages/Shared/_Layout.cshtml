<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FHIR Viewer</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FhirViewer.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="app-chrome">
        <header class="topbar">
            <div class="container shell-row">
                <a class="brand-mark" asp-area="" asp-page="/Index">FHIR Viewer</a>
                <span class="brand-subtitle">Consent-ready patient access and configurable FHIR browsing</span>
            </div>
        </header>

        <main role="main" class="container page-body">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
