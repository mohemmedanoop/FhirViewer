@page
@model HumanaPatientViewer.Web.Pages.IndexModel
@{
    ViewData["Title"] = "Humana Patient Access";
}

@functions {
    private static string GetErrorMessage(string? errorCode) => errorCode switch
    {
        "config" => "Humana OAuth settings are incomplete. Update the client id, secret, and redirect settings before signing in.",
        "callback" => "Humana did not return a usable authorization response.",
        "state" => "The OAuth state check failed. Please start the login flow again.",
        "refresh" => "A refresh token is not available for this session.",
        _ => "Unable to complete the request."
    };
}

<section class="hero-shell">
    <div class="hero-copy">
        <span class="eyebrow">FHIR member access</span>
        <h1>Humana patient consent and member data in one configurable .NET portal.</h1>
        <p class="hero-text">
            This starter app uses the Humana authorization-code flow, stores token details in session, and renders the requested FHIR resources in a browser-friendly workspace.
        </p>

        <div class="hero-actions">
            @if (!Model.Dashboard.IsAuthenticated)
            {
                <a class="btn btn-primary btn-lg" href="/auth/login">Connect with Humana</a>
            }
            else
            {
                <form method="post" action="/auth/refresh">
                    <button class="btn btn-primary btn-lg" type="submit">Refresh access token</button>
                </form>
                <form method="post" action="/auth/logout">
                    <button class="btn btn-outline-light btn-lg" type="submit">Clear session</button>
                </form>
            }
        </div>

        <p class="hint-text">@Model.Dashboard.LoginHint</p>
    </div>

    <aside class="hero-panel">
        <div class="metric-card">
            <span class="metric-label">Configured resources</span>
            <strong>@Model.Dashboard.RequestedResources.Count</strong>
            <p>@string.Join(", ", Model.Dashboard.RequestedResources)</p>
        </div>
        <div class="metric-card">
            <span class="metric-label">OAuth status</span>
            <strong>@(Model.Dashboard.IsAuthenticated ? "Connected" : "Waiting for consent")</strong>
            <p>Authorize once, then use the refresh token for later retrievals.</p>
        </div>
        <div class="metric-card">
            <span class="metric-label">Token expiry</span>
            <strong>@(Model.Dashboard.Token?.ExpiresAtUtc.ToLocalTime().ToString("g") ?? "Not available")</strong>
            <p>Patient id: @(Model.Dashboard.Token?.Patient ?? "Not available")</p>
        </div>
    </aside>
</section>

@if (!Model.Dashboard.IsConfigured)
{
    <div class="status-banner warning-banner">
        <strong>Configuration needed.</strong> Add your Humana client id and client secret in <code>appsettings</code> before starting the sign-in flow.
    </div>
}

@if (!string.IsNullOrWhiteSpace(Model.Dashboard.ErrorCode))
{
    <div class="status-banner danger-banner">
        <strong>Authentication issue.</strong> @GetErrorMessage(Model.Dashboard.ErrorCode)
    </div>
}

@if (!Model.Dashboard.IsAuthenticated)
{
    <section class="intro-grid">
        <article class="intro-card">
            <h2>How the flow works</h2>
            <p>The app redirects the member to Humana for consent, exchanges the returned authorization code for tokens, and then calls Humana FHIR endpoints with the patient-scoped bearer token.</p>
        </article>
        <article class="intro-card">
            <h2>Environment-ready configuration</h2>
            <p>Authority URL, FHIR base URL, redirect path, scopes, and requested resources all live in configuration so you can swap values across sandbox, QA, and production-style environments.</p>
        </article>
        <article class="intro-card">
            <h2>Resources included</h2>
            <p>Patient, Coverage, Explanation of Benefits, Goal, Immunization, MedicationRequest, Observation, Procedure, CarePlan, CareTeam, Condition, and DocumentReference.</p>
        </article>
    </section>
}
else
{
    <section class="sections-header">
        <div>
            <span class="eyebrow">Member workspace</span>
            <h2>FHIR resources returned through Humana consent</h2>
        </div>
        <p>Each panel below summarizes the first few resources for fast review and includes the raw JSON for implementation and troubleshooting.</p>
    </section>

    <section class="resource-grid">
        @foreach (var resourceSection in Model.Dashboard.Sections)
        {
            <article class="resource-section">
                <div class="section-topline">
                    <div>
                        <h3>@resourceSection.Heading</h3>
                        <p>@resourceSection.Description</p>
                    </div>
                    <span class="pill">@resourceSection.Total item(s)</span>
                </div>

                @if (!string.IsNullOrWhiteSpace(resourceSection.Error))
                {
                    <div class="status-banner muted-banner">
                        <strong>Unable to load @resourceSection.ResourceType.</strong> @resourceSection.Error
                    </div>
                }
                else if (resourceSection.Cards.Count == 0)
                {
                    <div class="empty-state">No entries were returned for this resource.</div>
                }
                else
                {
                    <div class="cards-grid">
                        @foreach (var card in resourceSection.Cards)
                        {
                            <div class="fhir-card">
                                <div class="card-header-line">
                                    <h4>@card.Title</h4>
                                    @if (!string.IsNullOrWhiteSpace(card.Subtitle))
                                    {
                                        <p>@card.Subtitle</p>
                                    }
                                </div>

                                <dl class="facts-list">
                                    @foreach (var fact in card.Facts)
                                    {
                                        <div>
                                            <dt>@fact.Label</dt>
                                            <dd>@fact.Value</dd>
                                        </div>
                                    }
                                </dl>

                                <details>
                                    <summary>View raw FHIR JSON</summary>
                                    <pre>@card.RawJson</pre>
                                </details>
                            </div>
                        }
                    </div>
                }
            </article>
        }
    </section>
}
