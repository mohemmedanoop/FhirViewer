{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Humana": {
    "AuthorityBaseUrl": "https://auth.humana.com/auth/oauth2/realms/root/realms/company_realm/authorize",
    "FhirBaseUrl": "https://sandbox-fhir.humana.com/api",
    "ClientId": "replace-with-humana-client-id",
    "ClientSecret": "replace-with-humana-client-secret",
    "UseApiKey": false,
    "ApiKeyHeaderName": "x-api-key",
    "ApiKey": "",
    "RedirectPath": "/auth/callback",
    "Scopes": [
      "openid",
      "offline_access",
      "launch/patient",
      "patient/Patient.read",
      "patient/Coverage.read",
      "patient/ExplanationOfBenefit.read",
      "patient/Goal.read",
      "patient/Immunization.read",
      "patient/MedicationRequest.read",
      "patient/Observation.read",
      "patient/Procedure.read",
      "patient/CarePlan.read",
      "patient/CareTeam.read",
      "patient/Condition.read",
      "patient/DocumentReference.read"
    ],
    "RequestedResources": [
      "Patient",
      "Coverage",
      "ExplanationOfBenefit",
      "Goal",
      "Immunization",
      "MedicationRequest",
      "Observation",
      "Procedure",
      "CarePlan",
      "CareTeam",
      "Condition",
      "DocumentReference"
    ]
  },
  "BrowserLaunch": {
    "Enabled": true,
    "RelativeUrl": "/"
  },
  "AllowedHosts": "*"
}
