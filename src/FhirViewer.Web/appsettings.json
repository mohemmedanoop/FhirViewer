{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "FhirConnection": {
    "AuthorityBaseUrl": "https://your-oauth-server",
    "FhirBaseUrl": "https://your-fhir-server",
    "ClientId": "replace-with-client-id",
    "ClientSecret": "replace-with-client-secret",
    "UseApiKey": false,
    "ApiKeyHeaderName": "x-api-key",
    "ApiKey": "",
    "RedirectPath": "/auth/callback",
    "Scopes": [
      "openid",
      "offline_access",
      "launch/patient",
      "patient/Patient.read",
      "patient/Coverage.read",
      "patient/ExplanationOfBenefit.read",
      "patient/Goal.read",
      "patient/Immunization.read",
      "patient/MedicationRequest.read",
      "patient/Observation.read",
      "patient/Procedure.read",
      "patient/CarePlan.read",
      "patient/CareTeam.read",
      "patient/Condition.read",
      "patient/DocumentReference.read"
    ],
    "RequestedResources": [
      "Patient",
      "Coverage",
      "ExplanationOfBenefit",
      "Goal",
      "Immunization",
      "MedicationRequest",
      "Observation",
      "Procedure",
      "CarePlan",
      "CareTeam",
      "Condition",
      "DocumentReference"
    ],
    "AppTitle": "FHIR Viewer",
    "AppSubtitle": "Configurable patient access experience",
    "WelcomeTitle": "A simple, welcoming way to browse consented FHIR data.",
    "WelcomeDescription": "Connect once, capture consent, and review patient, coverage, claims, medications, observations, and documents in one easy dashboard.",
    "ConnectButtonLabel": "Connect and view records",
    "LoginHint": "Update this helper text per environment so users know which identity or sandbox credentials to use for consent."
  },
  "BrowserLaunch": {
    "Enabled": true,
    "RelativeUrl": "/"
  },
  "AllowedHosts": "*"
}
